{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "watch", "api/index.ts"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3000
    },
    {
      "name": "ingestor",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "watch", "ingestor/index.ts"],
      "port": 0
    },
    {
      "name": "sanctions-cron",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "scripts/sync-sanctions.ts", "--cron"],
      "port": 0
    }
  ]
}
